<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Denver Airport Analytics — Deep Shukla</title>
<link href="https://fonts.googleapis.com/css2?family=Space+Mono:wght@400;700&family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
<style>
  *{margin:0;padding:0;box-sizing:border-box;}

  :root{
    --bg:#060d17;
    --card:#0c1a2e;
    --accent:#00d4ff;
    --accent2:#f5a623;
    --accent3:#4ade80;
    --purple:#a78bfa;
    --white:#ffffff;
    --body:#c8d8f0;
    --muted:#7a90b0;
    --border:rgba(0,212,255,0.14);
    --mono:'Space Mono',monospace;
    --sans:'Inter',sans-serif;
  }

  html{scroll-behavior:smooth;}

  body{
    background:var(--bg);
    color:var(--body);
    font-family:var(--sans);
    overflow-x:hidden;
    font-size:16px;
    line-height:1.7;
  }

  body::before{
    content:'';
    position:fixed;inset:0;
    background-image:
      linear-gradient(rgba(0,212,255,0.025) 1px,transparent 1px),
      linear-gradient(90deg,rgba(0,212,255,0.025) 1px,transparent 1px);
    background-size:48px 48px;
    pointer-events:none;z-index:0;
  }

  .orb{position:fixed;border-radius:50%;filter:blur(140px);pointer-events:none;z-index:0;}
  .orb1{width:700px;height:700px;background:rgba(0,212,255,0.055);top:-250px;left:-250px;}
  .orb2{width:500px;height:500px;background:rgba(245,166,35,0.045);bottom:0;right:-150px;}

  .wrap{
    max-width:1080px;
    margin:0 auto;
    padding:0 56px;
    position:relative;z-index:1;
  }

  /* ── HERO ── */
  .hero{
    padding:96px 0 80px;
    border-bottom:1px solid var(--border);
  }

  .eyebrow{
    font-family:var(--mono);
    font-size:11px;
    letter-spacing:.32em;
    color:var(--accent);
    text-transform:uppercase;
    margin-bottom:28px;
    opacity:0;
    animation:up .6s .05s forwards;
  }

  .hero h1{
    font-size:clamp(2.4rem,4.5vw,3.6rem);
    font-weight:800;
    color:var(--white);
    line-height:1.08;
    margin-bottom:24px;
    letter-spacing:-.02em;
    opacity:0;
    animation:up .6s .15s forwards;
  }

  .hero h1 em{
    font-style:normal;
    color:var(--accent);
  }

  .hero-desc{
    font-size:1.1rem;
    color:var(--body);
    max-width:640px;
    line-height:1.75;
    font-weight:400;
    opacity:0;
    animation:up .6s .28s forwards;
    margin-bottom:36px;
  }

  .tags{
    display:flex;flex-wrap:wrap;gap:10px;
    opacity:0;animation:up .6s .4s forwards;
  }

  .tag{
    font-family:var(--mono);
    font-size:10.5px;
    letter-spacing:.07em;
    padding:5px 14px;
    border:1px solid var(--border);
    border-radius:100px;
    color:var(--muted);
    background:rgba(0,212,255,0.04);
  }

  .links{
    display:flex;gap:16px;margin-top:36px;
    opacity:0;animation:up .6s .5s forwards;
  }

  .link-btn{
    display:inline-flex;align-items:center;gap:9px;
    padding:10px 22px;
    border-radius:8px;
    font-size:.88rem;
    font-weight:600;
    text-decoration:none;
    transition:transform .18s,box-shadow .18s;
    border:1.5px solid;
  }

  .link-btn:hover{transform:translateY(-2px);}

  .link-gh{
    background:#161b22;
    border-color:rgba(255,255,255,0.15);
    color:var(--white);
  }

  .link-gh:hover{box-shadow:0 6px 24px rgba(0,0,0,0.5);}

  .link-li{
    background:#0a66c2;
    border-color:#0a66c2;
    color:#fff;
  }

  .link-li:hover{box-shadow:0 6px 24px rgba(10,102,194,0.45);}

  .link-btn svg{flex-shrink:0;}

  /* ── SECTION COMMON ── */
  .section{
    padding:80px 0;
    border-bottom:1px solid var(--border);
  }

  .sec-label{
    font-family:var(--mono);
    font-size:10px;
    letter-spacing:.35em;
    color:var(--accent);
    text-transform:uppercase;
    margin-bottom:14px;
  }

  .sec-title{
    font-size:clamp(1.5rem,3vw,2rem);
    font-weight:700;
    color:var(--white);
    margin-bottom:16px;
    letter-spacing:-.02em;
    line-height:1.2;
  }

  .sec-body{
    font-size:1rem;
    color:var(--body);
    max-width:680px;
    line-height:1.8;
  }

  /* ── PIPELINE ── */
  .pipe-grid{
    display:grid;
    grid-template-columns:repeat(4,1fr);
    gap:0;
    margin-top:56px;
    position:relative;
  }

  .pipe-grid::before{
    content:'';
    position:absolute;
    top:27px;left:12%;right:12%;
    height:2px;
    background:linear-gradient(90deg,var(--accent),var(--accent2),var(--purple));
    opacity:.35;
  }

  .step{
    display:flex;flex-direction:column;align-items:center;
    text-align:center;padding:0 16px;
  }

  .step-num{
    width:54px;height:54px;border-radius:50%;
    display:flex;align-items:center;justify-content:center;
    font-family:var(--mono);font-size:13px;font-weight:700;
    border:2px solid;background:var(--bg);
    position:relative;z-index:1;margin-bottom:18px;
  }

  .step:nth-child(1) .step-num{border-color:var(--accent);color:var(--accent);}
  .step:nth-child(2) .step-num{border-color:var(--accent2);color:var(--accent2);}
  .step:nth-child(3) .step-num{border-color:var(--purple);color:var(--purple);}
  .step:nth-child(4) .step-num{border-color:var(--accent3);color:var(--accent3);}

  .step-name{
    font-family:var(--mono);font-size:12px;font-weight:700;
    letter-spacing:.06em;margin-bottom:10px;
  }

  .step:nth-child(1) .step-name{color:var(--accent);}
  .step:nth-child(2) .step-name{color:var(--accent2);}
  .step:nth-child(3) .step-name{color:var(--purple);}
  .step:nth-child(4) .step-name{color:var(--accent3);}

  .step p{font-size:.82rem;color:var(--muted);line-height:1.6;}

  /* why sql box */
  .sql-box{
    margin-top:48px;
    background:var(--card);
    border:1px solid var(--border);
    border-left:3px solid var(--purple);
    border-radius:12px;
    padding:32px 36px;
  }

  .sql-box h3{
    font-family:var(--mono);
    font-size:11px;letter-spacing:.2em;
    color:var(--purple);text-transform:uppercase;
    margin-bottom:14px;
  }

  .sql-box p{
    font-size:.97rem;
    color:var(--body);
    line-height:1.85;
    max-width:720px;
  }

  .sql-box strong{color:var(--white);font-weight:600;}

  /* ── STATS ── */
  .stats{
    display:grid;
    grid-template-columns:repeat(4,1fr);
    gap:18px;
    margin-top:48px;
  }

  .stat{
    background:var(--card);
    border:1px solid var(--border);
    border-radius:10px;
    padding:28px 20px;
    text-align:center;
    transition:border-color .2s,transform .2s;
  }

  .stat:hover{border-color:rgba(0,212,255,.35);transform:translateY(-3px);}

  .stat-n{
    font-family:var(--mono);
    font-size:2.2rem;font-weight:700;
    line-height:1;margin-bottom:8px;display:block;
  }

  .stat:nth-child(1) .stat-n{color:var(--accent);}
  .stat:nth-child(2) .stat-n{color:var(--accent2);}
  .stat:nth-child(3) .stat-n{color:var(--accent3);}
  .stat:nth-child(4) .stat-n{color:var(--purple);}

  .stat-l{font-size:.8rem;color:var(--muted);line-height:1.5;}

  /* ── EDA ── */
  .eda-intro{
    font-size:1rem;color:var(--body);
    line-height:1.8;max-width:720px;
    margin-bottom:40px;
  }

  .eda-grid{
    display:grid;
    grid-template-columns:1fr 1fr;
    gap:20px;
  }

  .eda-card{
    background:var(--card);
    border:1px solid var(--border);
    border-radius:12px;
    overflow:hidden;
    transition:transform .2s,border-color .2s;
  }

  .eda-card:hover{transform:translateY(-3px);border-color:rgba(0,212,255,.3);}

  .eda-head{padding:22px 24px 0;}

  .eda-title{
    font-family:var(--mono);font-size:10.5px;
    font-weight:700;letter-spacing:.14em;
    text-transform:uppercase;color:var(--accent);
    margin-bottom:6px;
  }

  .eda-desc{
    font-size:.83rem;color:var(--muted);
    line-height:1.6;margin-bottom:16px;
  }

  .chart-wrap{padding:0 24px 24px;}

  canvas{display:block;}

  /* ── DASHBOARDS ── */
  .dash-label{
    font-family:var(--mono);font-size:10px;
    letter-spacing:.22em;color:var(--accent);
    text-transform:uppercase;margin-bottom:10px;
    display:block;
  }

  .dash-title{
    font-size:1.1rem;font-weight:700;
    color:var(--white);margin-bottom:6px;
  }

  .dash-sub{font-size:.88rem;color:var(--muted);margin-bottom:20px;line-height:1.6;}

  .dash-frame{
    border-radius:12px;overflow:hidden;
    border:1px solid var(--border);
    position:relative;
  }

  .dash-frame img{width:100%;display:block;}

  .dash-pair{
    display:grid;
    grid-template-columns:1fr 1fr;
    gap:28px;
    margin-top:16px;
  }

  /* insight cards */
  .insights{
    display:grid;
    grid-template-columns:repeat(4,1fr);
    gap:16px;
    margin-top:40px;
  }

  .ins{
    background:var(--card);
    border:1px solid var(--border);
    border-radius:10px;
    padding:20px;
  }

  .ins-t{
    font-family:var(--mono);font-size:10px;
    letter-spacing:.1em;text-transform:uppercase;
    color:var(--white);margin-bottom:8px;
    display:block;
  }

  .ins-b{font-size:.83rem;color:var(--muted);line-height:1.6;}

  .ins:nth-child(1){border-top:2px solid var(--accent);}
  .ins:nth-child(2){border-top:2px solid var(--accent2);}
  .ins:nth-child(3){border-top:2px solid var(--accent3);}
  .ins:nth-child(4){border-top:2px solid var(--purple);}

  /* ── FOOTER ── */
  footer{
    padding:48px 0;
    text-align:center;
    position:relative;z-index:1;
  }

  footer p{
    font-family:var(--mono);font-size:11px;
    letter-spacing:.18em;color:var(--muted);
  }

  footer a{color:var(--accent);text-decoration:none;}
  footer a:hover{color:#fff;}

  /* anim */
  @keyframes up{
    from{opacity:0;transform:translateY(20px);}
    to{opacity:1;transform:translateY(0);}
  }

  .reveal{opacity:0;transform:translateY(24px);transition:opacity .65s ease,transform .65s ease;}
  .reveal.in{opacity:1;transform:none;}

  @media(max-width:900px){
    .wrap{padding:0 28px;}
    .pipe-grid{grid-template-columns:1fr 1fr;gap:32px;}
    .pipe-grid::before{display:none;}
    .stats{grid-template-columns:1fr 1fr;}
    .eda-grid{grid-template-columns:1fr;}
    .dash-pair{grid-template-columns:1fr;}
    .insights{grid-template-columns:1fr 1fr;}
  }
</style>
</head>
<body>
<div class="orb orb1"></div>
<div class="orb orb2"></div>

<!-- HERO -->
<div class="wrap">
<section class="hero">
  <p class="eyebrow">Data Engineering &amp; Analytics &mdash; Hackathon</p>
  <h1>Denver International Airport<br><em>Operational Analytics Pipeline</em></h1>
  <p class="hero-desc">
    Built an end-to-end pipeline that merged ServiceNow and Azure DevOps operational datasets, ran quantitative EDA in MATLAB, enforced schema via SQL, and delivered two interactive Power BI dashboards giving DEN both a customer-facing and internal view of enhancement delivery health.
  </p>
  <div class="tags">
